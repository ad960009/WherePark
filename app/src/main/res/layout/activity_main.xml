<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#1E1E1E"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvMyCarStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="차량 등록 필요 (버튼을 눌러 선택)"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnRegisterCar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="내 차 설정"
            android:textColor="#007AFF"
            style="@style/Widget.MaterialComponents.Button.TextButton" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardBackgroundColor="#2A2A2A"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="마지막 확인된 주차 위치"
                android:textColor="#AAAAAA"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvLastParkingLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="기록 없음"
                android:textColor="#00FF00"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp" />

            <!-- 시간 표시와 수동 선택 버튼을 나란히 배치하기 위한 레이아웃 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tvLastParkingTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="스캔 데이터가 없습니다."
                    android:textColor="#888888"
                    android:textSize="12sp" />

                <!-- 수동 선택 버튼 추가 -->
                <Button
                    android:id="@+id/btnManualSelect"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="수동 선택"
                    android:textColor="#FFBB00"
                    android:textSize="12sp"
                    android:paddingHorizontal="8dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="주변 장치 스캔"
            android:textColor="#00FF00"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDevices"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="12dp"
        android:background="#333333" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="등록된 주차 장치"
            android:textColor="#FFBB00"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRegisteredDevices"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

    <Button
        android:id="@+id/btnOpenMap"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="#FF4500"
        android:text="📍 지도에서 야외 위치 확인"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnScan"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:backgroundTint="#007AFF"
        android:text="스캔 시작"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF" />

</LinearLayout>